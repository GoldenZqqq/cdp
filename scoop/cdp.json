{
    "version": "2.0.5",
    "description": "A fast project directory switcher for PowerShell, WSL, and Vibe Coding CLI workflows.",
    "homepage": "https://github.com/GoldenZqqq/cdp",
    "license": "MIT",
    "url": "https://github.com/GoldenZqqq/cdp/releases/download/v2.0.5/cdp-2.0.5.tar.gz",
    "hash": "54bfc70012084b30e50d5ad05776382955eca520fe51329baa5293a051a99655",
    "extract_dir": "cdp-2.0.5",
    "depends": "fzf",
    "installer": {
        "script": [
            "& \"$dir\\Install.ps1\" -Scope CurrentUser -Force -SkipFzf"
        ]
    },
    "uninstaller": {
        "script": [
            "$modulePath = \"$env:USERPROFILE\\Documents\\PowerShell\\Modules\\cdp\"",
            "if (Test-Path $modulePath) { Remove-Item $modulePath -Recurse -Force }",
            "$modulePath = \"$env:USERPROFILE\\Documents\\WindowsPowerShell\\Modules\\cdp\"",
            "if (Test-Path $modulePath) { Remove-Item $modulePath -Recurse -Force }"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/GoldenZqqq/cdp/releases/download/v$version/cdp-$version.tar.gz",
        "extract_dir": "cdp-$version"
    }
}
